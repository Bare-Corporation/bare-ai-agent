#!/bin/bash
# ==============================================================================
# SCRIPT NAME:    bare-summarize
# DESCRIPTION:    Bare-AI Telemetry Harvester (Dynamic Agent)
# AUTHOR:         Cian Egan
# DATE:           2026-02-01
# VERSION:        3.0.0-Enterprise (Dynamic Role Detection)
#
# PURPOSE:
#   This is the "Sensory Organ" of the Bare-AI worker node.
#   It runs locally on the worker, gathers vital telemetry (RKE2 status,
#   Load, Memory), and formats it into a single-line JSON object.
#   This JSON is consumed by the central Brain over SSH.
#
# CHANGE LOG:
#   - v3.0.0: [FEAT] Added CPU temp tracking.
#   - v2.1.0: [FEAT] Added dynamic RKE2 role detection (Server vs Agent).
#             [FIX]  Added Agent ID lookup from config.
#   - v2.0.0: Initial separation from installer script.
# ==============================================================================
HOSTNAME=$(hostname)
IP=$(hostname -I | awk '{print $1}')
AGENT_ID=$(grep AGENT_ID ~/.bare-ai/config/agent.env 2>/dev/null | cut -d= -f2 || echo "unregistered")

# 1. Thermal Harvest (Hardware Agnostic via cpu-temp.sh)
if command -v cpu-temp.sh &> /dev/null; then
    TEMP=$(cpu-temp.sh | grep -oP '\d+\.?\d*(?=°C)' | head -1)
else
    TEMP="0"
fi
[ -z "$TEMP" ] && TEMP="0"

# 2. Service Status (RKE2)
if systemctl list-units --full -all | grep -q "rke2-server.service"; then
    RKE2_STATUS=$(systemctl is-active rke2-server)
    ROLE="server"
elif systemctl list-units --full -all | grep -q "rke2-agent.service"; then
    RKE2_STATUS=$(systemctl is-active rke2-agent)
    ROLE="agent"
else
    RKE2_STATUS="inactive"
    ROLE="unknown"
fi

# 3. Resource Metrics
LOAD=$(uptime | awk -F'load average:' '{ print $2 }' | xargs)
MEM_USED=$(free -m | awk '/Mem:/ { print $3 }')
MEM_TOTAL=$(free -m | awk '/Mem:/ { print $2 }')

# 4. JSON Output
printf '{"agent_id":"%s","hostname":"%s","ip":"%s","cpu_temp":%s,"rke2_status":"%s","role":"%s","load":"%s","mem_mb":%s,"mem_total_mb":%s}\n' \
    "$AGENT_ID" "$HOSTNAME" "$IP" "$TEMP" "$RKE2_STATUS" "$ROLE" "$LOAD" "$MEM_USED" "$MEM_TOTAL"
EOF

# Ensure it remains executable
chmod +x scripts/worker/bare-summarize
